{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",
    "module": "nodenext",
    "moduleResolution": "NodeNext",
    "target": "ESNext",
    "types": [
      "reflect-metadata"
    ],
    "sourceMap": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "noUncheckedIndexedAccess": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "strict": true,
    "isolatedModules": false,
    "skipLibCheck": true,
  },
  "exclude": [
    "node_modules",
    "dist",
    "**/*.test.ts"
  ]
}